# =============================================================================
# Billbird configuration
# Copy this file to .env and fill in your values:  cp env.example .env
# =============================================================================

# --- Required ----------------------------------------------------------------
# App will refuse to start without these.

# PostgreSQL connection string
DATABASE_URL=postgres://billbird:billbird@db:5432/billbird?sslmode=disable

# GitHub App (Settings > Developer settings > GitHub Apps > your app)
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=

# Paste the full PEM contents (including BEGIN/END markers).
# In docker-compose, wrap in quotes and use literal newlines.
GITHUB_PRIVATE_KEY=

# --- Allowed orgs (required) -------------------------------------------------
# Comma-separated list of GitHub org names. Only members of these orgs can
# use /log, /correct, /delete. Commands from non-members are rejected.
ALLOWED_ORGS=

# --- Admin panel (optional) --------------------------------------------------
# Without these the webhook endpoint still works, but the admin UI is disabled.

# GitHub OAuth (same app > OAuth settings)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Random string used to sign session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=

# --- Optional ----------------------------------------------------------------

# HTTP port (default 8080)
PORT=8080
